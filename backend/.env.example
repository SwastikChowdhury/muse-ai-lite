# Copy to backend/.env and fill in values. Never commit .env (it is gitignored).

# --- LLM & speech ---
GEMINI_API_KEY=
GROQ_API_KEY=

# --- MongoDB (chat transcripts, whispers, flagged messages) ---
MONGODB_URI=

# --- Postgres (user accounts, refresh tokens) ---
# Local dev (Postgres on host): postgresql+asyncpg://muse:muse@localhost:5432/muse
# Docker Compose overrides POSTGRES_URI for the app container via docker-compose.yml
POSTGRES_URI=

# --- Auth / JWT ---
JWT_SECRET=
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# --- Google OAuth (optional; register http://localhost:8000/auth/google/callback in Google Cloud) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Where Google OAuth redirects after login (Vite dev: :5173, Docker: :8000)
FRONTEND_URL=

# --- Safety / privacy ---
PII_SALT=
SUICIDE_THRESHOLD=
CRISIS_THRESHOLD=
TOXIC_THRESHOLD=
